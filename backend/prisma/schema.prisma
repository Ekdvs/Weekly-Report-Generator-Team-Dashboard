generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEAM_MEMBER
  MANAGER
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  LATE
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role
  reports   Report[]
  // Projects this user has been assigned to (many-to-many)
  projects  Project[] @relation("ProjectMembers")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  reports     Report[]
  // Team members assigned to this project (many-to-many)
  members     User[]   @relation("ProjectMembers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id             String        @id @default(cuid())
  weekStart      DateTime
  weekEnd        DateTime
  tasksCompleted String
  tasksPlanned   String
  blockers       String?
  hoursWorked    Float?
  notes          String?
  status         ReportStatus  @default(DRAFT)
  submittedAt    DateTime?
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  project        Project       @relation(fields: [projectId], references: [id])
  projectId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}
