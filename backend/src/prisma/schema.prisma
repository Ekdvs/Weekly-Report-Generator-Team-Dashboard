generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEAM_MEMBER
  MANAGER
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  LATE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  reports   Report[]
  projects  Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  reports     Report[]
  members     User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Report {
  id              String       @id @default(cuid())

  weekStart       DateTime
  weekEnd         DateTime

  tasksCompleted  String
  tasksPlanned    String
  blockers        String?
  hoursWorked     Float?
  notes           String?

  status          ReportStatus @default(DRAFT)
  submittedAt     DateTime?

  userId          String
  projectId       String

  user            User         @relation(fields: [userId], references: [id])
  project         Project      @relation(fields: [projectId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

